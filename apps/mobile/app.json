{
  "expo": {
    "name": "Volicious",
    "slug": "volicious",
    "scheme": "volicious",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#F4F2EC",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.volicious",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yakınındaki gerçekten en iyi mekanları göstermek için konumunu kullanıyoruz."
      }
    },
    "android": {
      "package": "app.volicious",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#A9B27E"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB1OsBwluIOfIC3SRjq_PMZNYMtSvYmOmY"
        }
      },
      "versionCode": 7
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Yakınındaki gerçekten en iyi mekanları göstermek için konumunu kullanıyoruz."
        }
      ],
      "expo-asset",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2707472203466324~8911844974",
          "iosAppId": "ca-app-pub-0000000000000000~0000000000",
          "userTrackingUsageDescription": "Sana daha alakalı reklamlar göstermek için kullanılır."
        }
      ],
      "./plugins/withKotlinMetadataSkip",
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "54410ef9-cbab-42c5-99f7-3e5c19dbd872"
      }
    },
    "owner": "eren_denizkusu"
  }
}
