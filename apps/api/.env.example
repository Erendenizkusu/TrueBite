# TrueBite API — ortam değişkenleri (kopyala: .env)
# Yerel Supabase değerleri için: supabase status

SUPABASE_URL=http://127.0.0.1:44321
SUPABASE_SERVICE_ROLE_KEY=<supabase status → SERVICE_ROLE_KEY>

# Cache-miss isteklerinde gerekli. Yoksa yalnızca cache-hit yolu çalışır.
GOOGLE_PLACES_API_KEY=

PORT=8787
CELL_PRECISION=6

# ─── Maliyet güvenliği (RELEASE.md § A / altın kural) ───
# Cihaz-başına GÜNLÜK ücretsiz istek; bitince reklam izle → +istek.
FREE_REQUESTS_PER_DAY=2
# Bir rewarded ad kaç ek istek kazandırır.
AD_GRANT_REQUESTS=1
# Global GÜNLÜK / AYLIK Google Places çağrı tavanı (sert maliyet koruması).
# ~$0.032/çağrı, cache-miss başına ~5 çağrı. Deploy'da trafik/bütçeye göre ayarla.
DAILY_GOOGLE_BUDGET=300
MONTHLY_GOOGLE_BUDGET=5000
