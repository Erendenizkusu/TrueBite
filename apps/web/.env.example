# Volicious web — ortam değişkenleri (kopyala: .env.local)
# Backend (@truebite/api) adresi. Yerelde:
API_BASE_URL=http://localhost:8787

# Web reklam (Google AdSense) — BOŞSA reklam çıkmaz (default-kapalı, güvenli).
# AdSense onayı + domain gelince doldur:
#   NEXT_PUBLIC_ADSENSE_CLIENT = yayıncı ID (ca-pub-XXXXXXXXXXXXXXXX)
#   NEXT_PUBLIC_ADSENSE_SLOT_FEED = sonuç-altı reklam biriminin slot ID'si
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_FEED=
